# Ankara — Environment Configuration
# Copy to .env and adjust as needed.

# Forensic Reasoning Engine runs on LOCAL Ollama (Llama 3.2) by default.
# No API key, no network egress.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Optional cloud fallbacks (only used if LLM_PROVIDER is set to one of these):
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# API settings
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# Device override (auto-detected if empty: mps > cuda > cpu)
# DEVICE=mps

# Detection threshold
FAKE_THRESHOLD=0.5
